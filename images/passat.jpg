  opacity: 0.4;
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */#rewid-af {
  position: absolute;
  z-index: 10;
  top: 50px;
  right: 0;
  font-size: 0;
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1), 0 2px 4px 1px rgba(0, 0, 0, 0.18);
  border-radius: 5px;
}

#rewid-af:dir(rtl) {
  right: auto;
  left: 0;
}

#rewid-af iframe {
  border-radius: 5px;
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */#rewid-f {
  position: fixed;
  right: 0;
  top: 0;
  width: 376px;
  height: 100vh;
  z-index: 1100;
  box-shadow: 0 0 0 1px #0000000d, 0 0 0 2px #0000001a;
}

.b_pinhead #b_header #id_h #id_rh_w #rewid-f {
  visibility: visible;
}

#rewid-f.modern {
  position: absolute;
  z-index: 10;
  top: 50px;
  right: 0;
  font-size: 0;
  width: 0vh;
  height: 0vh;
  visibility: none;
}

#rewid-f.modern iframe {
  border-radius: 5px;
}

#rewid-f:dir(rtl) {
  right: auto;
  left: 0;
}

